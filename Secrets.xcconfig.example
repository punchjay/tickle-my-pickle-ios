// Copy this file to Secrets.xcconfig (gitignored) and fill in a real key.
//
// Create the key in Google Cloud Console -> APIs & Services -> Credentials:
//   Application restriction: iOS apps, bundle id com.punchjay.ticklemypickle
//   API restriction: Geocoding API, Places API (New)
//
// Unlike the old Expo app, this key does NOT need to stay unrestricted or
// referrer-restricted for REST calls to work -- GooglePlacesClient sends the
// X-Ios-Bundle-Identifier header on every request, which is what Google's iOS
// app restriction checks against.
GOOGLE_MAPS_REST_API_KEY = YOUR_KEY_HERE
